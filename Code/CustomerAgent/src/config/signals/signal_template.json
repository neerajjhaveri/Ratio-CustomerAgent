{
  "signal_types": [
    {
      "id": "SIG-TYPE-1",
      "name": "SLI Breach Detected",
      "description": "One or more SLIs have impacted resources with degraded values over a meaningful duration, as reported by SLI monitoring data.",
      "data_source": "SLI breach Kusto query",
      "data_fields": ["CustomerName", "SubscriptionId", "Region", "SLO_SliId", "ImpactedResources", "TotalImpactDurationMin", "EarliestImpactStart", "LatestImpactEnd", "AvgValueAcrossWindows", "MinValueAcrossWindows"],
      "collection_tools": [
        {
          "tool_name": "collect_impacted_resource_customer_tool",
          "parameters_from_context": {
            "service_tree_id": "service_tree_id",
            "customer_name": "customer_name"
          },
          "feeds_granularities": ["subscription_region", "cross_region", "cross_subscription", "multi_sli"]
        },
        {
          "tool_name": "collect_impacted_resource_multicustomer_tool",
          "parameters_from_context": {
            "service_tree_id": "service_tree_id"
          },
          "feeds_granularities": ["multi_customer_same_region_sli", "multi_sli_region_wide"]
        }
      ],
      "granularities": [
        {
          "granularity": "subscription_region",
          "group_by": ["CustomerName", "SubscriptionId", "Region", "SLO_SliId"],
          "confidence": "Medium",
          "rationale": "A single subscription+region SLI breach is the base signal. Could be localized noise or a real issue — confidence increases with severity (near-zero values) and duration.",
          "inputs": ["customer_name", "subscription_id", "region", "slo_sli_id", "impacted_resources", "total_impact_duration_min", "avg_value_across_windows", "min_value_across_windows"],
          "activation": "impacted_resources >= 1",
          "activation_rules": [
            {"impacted_resources_min": 1}
          ],
          "strength_formula": "impacted_resources * log2(1 + total_impact_duration_min / 5) * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 30.0
        },
        {
          "granularity": "cross_region",
          "group_by": ["CustomerName", "SLO_SliId"],
          "aggregates": {
            "distinct_regions": "count_distinct(Region)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "avg_value_across_windows": "avg(AvgValueAcrossWindows)"
          },
          "confidence": "High",
          "rationale": "The same SLI breached across multiple distinct regions indicates a widespread platform issue rather than a region-specific problem.",
          "inputs": ["customer_name", "slo_sli_id", "region", "impacted_resources", "total_impact_duration_min", "avg_value_across_windows", "min_value_across_windows"],
          "activation": "distinct_regions >= 2",
          "activation_rules": [
            {"distinct_regions_min": 2}
          ],
          "strength_formula": "distinct_regions * total_impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "cross_subscription",
          "group_by": ["CustomerName", "SLO_SliId"],
          "aggregates": {
            "distinct_subscriptions": "count_distinct(SubscriptionId)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "avg_value_across_windows": "avg(AvgValueAcrossWindows)"
          },
          "confidence": "High",
          "rationale": "The same SLI breached across multiple subscriptions for the same customer rules out subscription-specific misconfiguration — likely a platform-level or customer-wide issue.",
          "inputs": ["customer_name", "slo_sli_id", "subscription_id", "impacted_resources", "total_impact_duration_min", "avg_value_across_windows"],
          "activation": "distinct_subscriptions >= 2",
          "activation_rules": [
            {"distinct_subscriptions_min": 2}
          ],
          "strength_formula": "distinct_subscriptions * total_impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "multi_sli",
          "group_by": ["CustomerName", "SubscriptionId", "Region"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_resources": "sum(ImpactedResources)"
          },
          "confidence": "High",
          "rationale": "Multiple distinct SLIs breached for the same subscription+region indicates a broader systemic issue rather than a single SLI anomaly.",
          "inputs": ["customer_name", "subscription_id", "region", "slo_sli_id", "impacted_resources"],
          "activation": "distinct_sli_count >= 2",
          "activation_rules": [
            {"distinct_sli_count_min": 2}
          ],
          "strength_formula": "distinct_sli_count * total_impacted_resources",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "multi_customer_same_region_sli",
          "group_by": ["Region", "SLO_SliId"],
          "aggregates": {
            "impacted_subscriptions": "sum(ImpactedSubscriptions)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "avg_value_across_windows": "avg(AvgValueAcrossWindows)"
          },
          "confidence": "High",
          "rationale": "Multiple subscriptions across different customers breaching the same SLI in the same region indicates a regional platform issue. Primary customer resources in the same region are at risk of impact spill-over.",
          "inputs": ["region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows", "min_value_across_windows"],
          "activation": "impacted_subscriptions >= 3",
          "activation_rules": [
            {"impacted_subscriptions_min": 3}
          ],
          "strength_formula": "impacted_subscriptions * total_impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 80.0
        },
        {
          "granularity": "multi_sli_region_wide",
          "group_by": ["Region"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "impacted_subscriptions": "sum(ImpactedSubscriptions)",
            "total_impacted_resources": "sum(ImpactedResources)"
          },
          "confidence": "High",
          "rationale": "Multiple distinct SLIs breached across customers in the same region indicates broad regional degradation — not a single-SLI anomaly. Primary customer resources co-located in this region face elevated risk.",
          "inputs": ["region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows"],
          "activation": "distinct_sli_count >= 2",
          "activation_rules": [
            {"distinct_sli_count_min": 2}
          ],
          "strength_formula": "distinct_sli_count * impacted_subscriptions * total_impacted_resources",
          "max_raw_strength": 200.0
        }
      ]
    },
    {
      "id": "SIG-TYPE-2",
      "name": "Customer Raised Support Request",
      "description": "Customer has raised one or more support cases, indicating they are experiencing issues with Azure services.",
      "data_source": "Support case Kusto query",
      "data_fields": ["CaseNumber", "Title", "State", "IsCritSit", "SupportProductName", "ResourceUri", "CreatedDateTime", "IsEscalated", "InitialSeverity", "Severity", "AzureSubscriptionId", "Customer_TPID", "Customer_CloudCustomerName"],
      "collection_tools": [
        {
          "tool_name": "collect_support_request_tool",
          "parameters_from_context": {
            "customer_name": "customer_name",
            "lookback_hours": "lookback_hours",
            "support_product_names": "support_product_names"
          },
          "feeds_granularities": ["single_case", "crit_sit", "escalated", "multi_case_same_product"]
        },
        {
          "tool_name": "collect_support_request_tool",
          "parameters_from_context": {
            "lookback_hours": "lookback_hours",
            "support_product_names": "support_product_names"
          },
          "feeds_granularities": ["multi_customer_same_product"]
        }
      ],
      "granularities": [
        {
          "granularity": "single_case",
          "group_by": ["CaseNumber"],
          "confidence": "Medium",
          "rationale": "A single support case is a meaningful signal but could be routine. Confidence increases with severity and CritSit/escalation flags.",
          "inputs": ["case_number", "title", "state", "is_crit_sit", "support_product_name", "resource_uri", "created_date_time", "is_escalated", "initial_severity", "severity", "azure_subscription_id", "customer_tpid", "customer_name"],
          "activation": "case exists",
          "activation_rules": [
            {"case_count_min": 1}
          ],
          "strength_formula": "(severity == 'A' ? 3 : severity == 'B' ? 2 : 1) * (is_crit_sit ? 3 : 1)",
          "max_raw_strength": 9.0
        },
        {
          "granularity": "crit_sit",
          "group_by": ["CaseNumber"],
          "confidence": "High",
          "rationale": "A CritSit flag means the customer or support engineer has declared a critical situation — this is a high-urgency signal that demands immediate attention.",
          "inputs": ["case_number", "title", "state", "support_product_name", "resource_uri", "created_date_time", "severity", "azure_subscription_id", "customer_tpid", "customer_name"],
          "activation": "is_crit_sit == True",
          "activation_rules": [
            {"is_crit_sit": true}
          ],
          "strength_formula": "(severity == 'A' ? 3 : 2) * 3",
          "max_raw_strength": 9.0
        },
        {
          "granularity": "escalated",
          "group_by": ["CaseNumber"],
          "confidence": "High",
          "rationale": "An escalated case or one where severity increased post-filing indicates the issue is more serious than initially assessed. This strengthens the signal.",
          "inputs": ["case_number", "title", "state", "support_product_name", "resource_uri", "created_date_time", "is_escalated", "initial_severity", "severity", "azure_subscription_id", "customer_tpid", "customer_name"],
          "activation": "is_escalated == True or severity > initial_severity",
          "activation_rules": [
            {"is_escalated_or_severity_increased": true}
          ],
          "strength_formula": "(severity == 'A' ? 3 : severity == 'B' ? 2 : 1) * 2",
          "max_raw_strength": 6.0
        },
        {
          "granularity": "multi_case_same_product",
          "group_by": ["SupportProductName"],
          "aggregates": {
            "case_count": "count(CaseNumber)",
            "max_severity": "min(Severity)"
          },
          "confidence": "High",
          "rationale": "Multiple support cases for the same SupportProductName from the same customer suggests a systemic product issue rather than an isolated incident.",
          "inputs": ["case_number", "title", "support_product_name", "created_date_time", "severity", "azure_subscription_id", "customer_tpid", "customer_name"],
          "activation": "distinct_cases_same_product >= 2",
          "activation_rules": [
            {"distinct_cases_same_product_min": 2}
          ],
          "strength_formula": "case_count * (max_severity == 'A' ? 3 : max_severity == 'B' ? 2 : 1)",
          "max_raw_strength": 15.0
        },
        {
          "granularity": "multi_customer_same_product",
          "group_by": ["SupportProductName"],
          "aggregates": {
            "customer_count": "count_distinct(Customer_CloudCustomerName)",
            "total_case_count": "count(CaseNumber)",
            "max_severity": "min(Severity)"
          },
          "confidence": "High",
          "rationale": "Multiple distinct customers filing support cases for the same product indicates a platform-wide service issue rather than a customer-specific problem.",
          "inputs": ["case_number", "title", "support_product_name", "created_date_time", "severity", "azure_subscription_id", "customer_name"],
          "activation": "distinct_customers_same_product >= 2",
          "activation_rules": [
            {"distinct_customers_same_product_min": 2}
          ],
          "strength_formula": "customer_count * total_case_count * (max_severity == 'A' ? 3 : max_severity == 'B' ? 2 : 1)",
          "max_raw_strength": 40.0
        }
      ]
    },
    {
      "id": "SIG-TYPE-3",
      "name": "Service Team Creates Incident",
      "description": "Service team has created an incident as a response to internal detection or external reports.",
      "data_source": "Incident Kusto query",
      "data_fields": ["IncidentId", "Severity", "IsOutage", "Status", "Title", "CreateDate", "ImpactStartDate", "ChildCount", "SupportTicketId", "OwningTenantName"],
      "collection_tools": [
        {
          "tool_name": "collect_incident_details_tool",
          "parameters_from_context": {
            "lookback_hours": "lookback_hours",
            "owning_tenant_names": "owning_tenant_names"
          },
          "feeds_granularities": ["single_incident", "outage_confirmed", "with_child_incidents", "customer_correlated"]
        }
      ],
      "granularities": [
        {
          "granularity": "single_incident",
          "group_by": ["IncidentId"],
          "confidence": "Medium",
          "rationale": "A single incident from a service team is a meaningful signal but many incidents are exploratory or low-impact. Confidence increases with severity and outage confirmation.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "create_date", "impact_start_date", "child_count", "support_ticket_id", "owning_tenant_name"],
          "activation": "incident exists",
          "activation_rules": [
            {"incident_count_min": 1}
          ],
          "strength_formula": "(4 - severity) * (is_outage ? 2 : 1)",
          "max_raw_strength": 6.0
        },
        {
          "granularity": "outage_confirmed",
          "group_by": ["IncidentId"],
          "confidence": "High",
          "rationale": "When IsOutage is true, the service team has explicitly confirmed customer-facing impact. This is one of the strongest signals available.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "impact_start_date", "owning_tenant_name"],
          "activation": "is_outage == true",
          "activation_rules": [
            {"is_outage": true}
          ],
          "strength_formula": "(4 - severity) * 2",
          "max_raw_strength": 6.0
        },
        {
          "granularity": "with_child_incidents",
          "group_by": ["IncidentId"],
          "confidence": "High",
          "rationale": "Incidents with child incidents indicate widespread impact — multiple teams or regions are involved. The more children, the broader the issue.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "child_count", "owning_tenant_name"],
          "activation": "child_count >= 5",
          "activation_rules": [
            {"child_count_min": 5}
          ],
          "strength_formula": "child_count * (4 - severity)",
          "max_raw_strength": 50.0
        },
        {
          "granularity": "customer_correlated",
          "group_by": ["IncidentId"],
          "confidence": "High",
          "rationale": "When an incident has a linked SupportTicketId, it directly correlates a platform incident with a customer complaint — strong evidence of customer impact.",
          "inputs": ["incident_id", "severity", "status", "title", "support_ticket_id", "owning_tenant_name"],
          "activation": "support_ticket_id is not empty",
          "activation_rules": [
            {"support_ticket_id_present": true}
          ],
          "strength_formula": "(4 - severity) * 1.5",
          "max_raw_strength": 4.5
        }
      ]
    },
    {
      "id": "SIG-TYPE-4",
      "name": "Dependency Service Degradation",
      "description": "Dependency services (Allocator, CIS, Regional Network Manager, etc.) that the primary customer service relies on show SLI breaches in regions where the customer has resources. Detected proactively — before customer impact spills over.",
      "data_source": "SLI breach Kusto query (multi-customer) per dependency service, filtered to customer regions",
      "data_fields": ["DependencyServiceName", "Region", "SLO_SliId", "ImpactedResources", "ImpactedSubscriptions", "TotalImpactDurationMin", "EarliestImpactStart", "LatestImpactEnd", "AvgValueAcrossWindows", "MinValueAcrossWindows"],
      "collection_strategy": "dependency_scan",
      "dependency_mappings": "dependency_mappings.json",
      "region_tool": {
        "tool_name": "collect_customer_region_tool",
        "parameters_from_context": {
          "service_tree_id": "service_tree_id",
          "customer_name": "customer_name"
        }
      },
      "dependency_tool": {
        "tool_name": "collect_impacted_resource_multicustomer_tool",
        "parameter_field": "service_tree_id"
      },
      "granularities": [
        {
          "granularity": "dep_sli_breach_in_customer_region",
          "group_by": ["DependencyServiceName", "Region", "SLO_SliId"],
          "confidence": "Medium",
          "rationale": "A single dependency service SLI breach in a customer region is the base dependency signal. The dependency is degraded where the customer has resources — this is a leading indicator of potential spill-over.",
          "inputs": ["dependency_service_name", "region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows", "min_value_across_windows"],
          "activation": "impacted_resources >= 1",
          "activation_rules": [
            {"impacted_resources_min": 10}
          ],
          "strength_formula": "impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "multi_dep_sli_breach_in_region",
          "group_by": ["DependencyServiceName", "Region"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "total_impacted_subscriptions": "sum(ImpactedSubscriptions)",
            "avg_value_across_windows": "avg(AvgValueAcrossWindows)"
          },
          "confidence": "High",
          "rationale": "Multiple SLIs breached for the same dependency service in a customer region indicates broad service-level degradation, not a single-SLI anomaly.",
          "inputs": ["dependency_service_name", "region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows"],
          "activation": "distinct_sli_count >= 2",
          "activation_rules": [
            {"distinct_sli_count_min": 2}
          ],
          "strength_formula": "distinct_sli_count * total_impacted_subscriptions * total_impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 200.0
        },
        {
          "granularity": "multi_dep_service_breach_in_region",
          "group_by": ["Region"],
          "aggregates": {
            "distinct_dep_count": "count_distinct(DependencyServiceName)",
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "total_impacted_subscriptions": "sum(ImpactedSubscriptions)"
          },
          "confidence": "High",
          "rationale": "Multiple dependency services degraded in the same customer region indicates a broad regional platform issue — resource exhaustion, infrastructure failure, or cascading dependency chain breakage.",
          "inputs": ["dependency_service_name", "region", "slo_sli_id", "impacted_resources", "impacted_subscriptions"],
          "activation": "distinct_dep_count >= 2",
          "activation_rules": [
            {"distinct_dep_count_min": 2}
          ],
          "strength_formula": "distinct_dep_count * distinct_sli_count * total_impacted_subscriptions",
          "max_raw_strength": 100.0
        }
      ]
    }
  ],
  "compound_signals": [
    {
      "id": "COMPOUND-001",
      "name": "Correlated Degradation Across All Sources",
      "description": "All three independent data sources (SLI, support, incident) show concurrent activity — unlikely to be coincidental.",
      "required_signal_types": ["SIG-TYPE-1", "SIG-TYPE-2", "SIG-TYPE-3"],
      "activation_rules": [
        {"min_types_with_data": 3}
      ],
      "confidence": "High",
      "strength_formula": "sum(type_max_strengths) * 2.0",
      "correlation_multiplier": 2.0,
      "rationale": "Three independent data sources showing concurrent activity is the strongest compound signal. Even individually weak signals become meaningful when all three agree."
    },
    {
      "id": "COMPOUND-002",
      "name": "SLI Breach with Customer Complaints",
      "description": "SLI degradation detected alongside customer support activity, confirming customer-visible impact.",
      "required_signal_types": ["SIG-TYPE-1", "SIG-TYPE-2"],
      "activation_rules": [
        {"min_types_with_data": 2}
      ],
      "confidence": "Medium-High",
      "strength_formula": "sum(type_max_strengths) * 1.5",
      "correlation_multiplier": 1.5,
      "rationale": "SLI data proves platform degradation; support case proves customer awareness. Together they confirm actionable impact even when neither is individually strong."
    },
    {
      "id": "COMPOUND-003",
      "name": "Incident with SLI Correlation",
      "description": "Service team incident coincides with measurable SLI degradation, confirming the incident has real performance impact.",
      "required_signal_types": ["SIG-TYPE-3", "SIG-TYPE-1"],
      "activation_rules": [
        {"min_types_with_data": 2}
      ],
      "confidence": "Medium-High",
      "strength_formula": "sum(type_max_strengths) * 1.5",
      "correlation_multiplier": 1.5,
      "rationale": "An incident alone could be exploratory; SLI data confirms real resource impact."
    },
    {
      "id": "COMPOUND-004",
      "name": "Incident with Customer Complaints",
      "description": "Service team incident coincides with customer support cases, confirming both team awareness and customer impact.",
      "required_signal_types": ["SIG-TYPE-3", "SIG-TYPE-2"],
      "activation_rules": [
        {"min_types_with_data": 2}
      ],
      "confidence": "Medium-High",
      "strength_formula": "sum(type_max_strengths) * 1.5",
      "correlation_multiplier": 1.5,
      "rationale": "Incident proves the team knows; support case proves the customer is affected."
    },
    {
      "id": "COMPOUND-005",
      "name": "Dependency Degradation with Customer SLI Impact",
      "description": "Dependency service degradation detected alongside customer SLI breaches — confirms the dependency issue is cascading into customer-visible impact.",
      "required_signal_types": ["SIG-TYPE-4", "SIG-TYPE-1"],
      "activation_rules": [
        {"min_types_with_data": 2}
      ],
      "confidence": "High",
      "strength_formula": "sum(type_max_strengths) * 1.5",
      "correlation_multiplier": 1.5,
      "rationale": "SIG-TYPE-4 alone is a leading indicator; when SIG-TYPE-1 also shows customer SLI breaches in the same region, it confirms the dependency degradation is actively impacting the customer. This is the causal chain: dependency → customer."
    },
    {
      "id": "COMPOUND-006",
      "name": "Dependency Degradation with Customer Complaints",
      "description": "Dependency service degradation detected alongside customer support cases — dependency issue is causing customer-reported problems.",
      "required_signal_types": ["SIG-TYPE-4", "SIG-TYPE-2"],
      "activation_rules": [
        {"min_types_with_data": 2}
      ],
      "confidence": "High",
      "strength_formula": "sum(type_max_strengths) * 1.5",
      "correlation_multiplier": 1.5,
      "rationale": "SIG-TYPE-4 provides the root cause (dependency degradation); SIG-TYPE-2 provides customer evidence. Together they explain WHY the customer is filing tickets."
    }
  ],
  "scoring": {
    "scale_max": 5,
    "min_activated_floor": 0.5,
    "labels": {
      "0": "None",
      "1": "Low",
      "2": "Moderate",
      "3": "Significant",
      "4": "High",
      "5": "Critical"
    }
  },
  "decision_thresholds": {
    "strong_individual_signal_min_strength": 2.5,
    "compound_activation_note": "If no individual signal exceeds strong_individual_signal_min_strength, compound signals are evaluated. Any activated compound triggers the GroupChat.",
    "actions": {
      "strong_individual_or_compound": "invoke_group_chat",
      "weak_individual_only": "watchlist",
      "no_signals": "quiet"
    }
  },
  "confidence_levels": ["Low", "Medium", "Medium-High", "High", "Highest"],
  "confidence_principle": "Confidence increases as granularity broadens (subscription -> region -> global) and as breadth increases (single SLI -> multiple SLIs -> cross-service).",
  "adaptive_thresholds_note": "Broader impact (more SLIs, more services) lowers the required degradation %. Sustained duration also lowers the bar. A 0.5% dip on one SLI for 5 minutes is noise; a 0.5% dip across 4 services for 30 minutes is real.",
  "customer_context_note": "Customer bucket memberships (S500, Unified, ACE) and subscription criticality are attributes attached to affected subscriptions, not signal filters. When a signal fires, impacted subscriptions are enriched with their customer context for triage prioritization."
}
